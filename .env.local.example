# ─────────────────────────────────────────────────────────────────
# CEOVIA — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Shopify Storefront API
# Store domain: found in Shopify Admin → Settings → Domains
# Format: your-store-name.myshopify.com (no https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=ceovia.myshopify.com

# Shopify Storefront Access Token (public — safe to expose in browser)
# How to create: Shopify Admin → Apps → Develop apps → [your app]
#   → Configuration → Storefront API access scopes
#   → Required scope: unauthenticated_write_checkouts
#   → Install app → Copy the Storefront API access token
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token_here

# Shopify Selling Plan ID for the Subscribe & Save variant
# Leave empty until Selling Plans are configured in Shopify Admin → Products → Purchase options.
# When empty: subscription card renders as "Coming soon" and cannot be selected.
# Format: gid://shopify/SellingPlan/XXXXX
# How to find: Shopify Admin → Apps → GraphiQL Explorer:
#   query { product(id:"...") { sellingPlanGroups(first:5) { edges {
#     node { sellingPlans(first:5) { edges { node { id name } } } } } } } }
NEXT_PUBLIC_CEOVIA_SELLING_PLAN_ID=
